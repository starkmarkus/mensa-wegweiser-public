PORT=3000

# Optional: hosted OpenAI-compatible language-model endpoint.
SAIA_API_KEY=
SAIA_BASE_URL=https://chat-ai.academiccloud.de/v1
SAIA_MODEL=mistral-large-3-675b-instruct-2512
SAIA_TEMPERATURE=0.2
SAIA_TOP_P=1

# Optional: local-only LLM via Ollama. Disabled by default.
# Start Ollama locally, then set USE_OLLAMA=true.
USE_OLLAMA=false
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:1b

# Privacy default: do not store chat transcripts.
LOG_CHAT_TRANSCRIPTS=false
APP_PASSWORD=change_this_to_a_long_random_password

# Optional: send feedback form submissions via Resend.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=Atlas Feedback <onboarding@resend.dev>

# Optional: fallback endpoint if Resend is not configured in this project.
FEEDBACK_PROXY_URL=
